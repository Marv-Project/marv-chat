{
  "name": "marv-chat",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^25.2.3",
      "dotenv": "^17.2.4",
      "eslint": "^10.0.0",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev": "turbo dev",
    "dev:web": "turbo -F web dev",
    "lint": "turbo run lint"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@marv-chat/config": "workspace:*",
    "@marv-chat/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.7",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.8"
}
