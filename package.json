      "better-auth": "^1.4.18",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "dotenv": "^17.2.4",
      "drizzle-kit": "^0.31.9",
      "drizzle-orm": "^0.45.1",
      "eslint": "^10.0.0",
      "lucide-react": "^0.545.0",
      "pg": "^8.18.0",
      "radix-ui": "^1.4.3",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "shadcn": "^3.8.4",
