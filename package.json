    ],
    "catalog": {
      "@base-ui/react": "^1.2.0",
      "@fontsource-variable/inter": "^5.2.8",
      "@tabler/icons-react": "^3.36.1",
      "@types/node": "^25.2.3",
      "@types/pg": "^8.16.0",
