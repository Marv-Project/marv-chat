{
  "name": "@marv-chat/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "lint": "eslint ."
  },
  "dependencies": {
    "@marv-chat/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@marv-chat/config": "workspace:*",
    "@marv-chat/eslint-config": "workspace:*",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
